	"name": "AmenityCraft",
	"description": "A mod for household accessories and furniture.",
	"authors": [
		"Harshit"
	],
	"contact": {
		"homepage": "https://fabricmc.net/",
		"sources": "https://github.com/FabricMC/fabric-example-mod"
	},
